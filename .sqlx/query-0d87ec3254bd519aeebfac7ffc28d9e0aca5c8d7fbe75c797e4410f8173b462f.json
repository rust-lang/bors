  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            uc.rollup,\n            uc.member,\n            perf_build AS \"build: BuildModel\"\n        FROM unrolled_commit uc\n            LEFT JOIN build perf_build ON perf_build.id = uc.perf_build_id\n        WHERE uc.rollup = $1\n            ",
